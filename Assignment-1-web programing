<!--
Problem Statement 1:
Create a landing page for a startup company offering digital marketing services.
The page should include:
- A hero section
- Services section
- About the company
- Client testimonials
- Contact information
-->



<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Digital Boost</title>
<style>
body {font-family: Arial; margin:0;}
header {background:#0a2540; color:white; padding:60px; text-align:center;}
section {padding:40px;}
.services, .testimonials {display:flex; gap:20px;}
.card {padding:20px; background:#f4f4f4; border-radius:10px;}
footer {background:#0a2540; color:white; text-align:center; padding:20px;}
</style>
</head>
<body>

<header>
<h1>Grow Your Business Online 🚀</h1>
<p>We provide powerful digital marketing solutions</p>
</header>

<section>
<h2>Our Services</h2>
<div class="services">
<div class="card">SEO Optimization</div>
<div class="card">Social Media Marketing</div>
<div class="card">Google Ads</div>
</div>
</section>

<section>
<h2>About Us</h2>
<p>We are a team of digital experts helping brands grow online.</p>
</section>

<section>
<h2>Testimonials</h2>
<div class="testimonials">
<div class="card">"Amazing growth!"</div>
<div class="card">"Highly recommend!"</div>
</div>
</section>

<section>
<h2>Contact</h2>
<p>Email: contact@digitalboost.com</p>
</section>

<footer>© 2026 Digital Boost</footer>

</body>
</html>



